setup_tailscale() {
    echo -e "${CYAN}🔐 Tailscale Setup${NC}\n"

    ensure_tailscale

    if [[ "$SETUP_MODE" == "agent" ]]; then
        if [[ -n "${TAILSCALE_AUTHKEY:-}" ]]; then
            tailscale up --authkey="$TAILSCALE_AUTHKEY" &>>"$LOG_FILE"
            local ts_ip
            ts_ip=$(tailscale ip -4 2>/dev/null || echo "")
            print_success "Authenticated with auth key"
            [[ -n "$ts_ip" ]] && print_success "Tailscale IP: $ts_ip"
        else
            print_warning "No TAILSCALE_AUTHKEY env var. Run: sudo tailscale up"
        fi
        return
    fi

    echo -e "${YELLOW}[1]${NC} ${BOLD}Auth Key${NC} ${GREEN}(Recommended)${NC}"
    echo -e "    ${CYAN}→${NC} Get from: https://login.tailscale.com/admin/settings/keys\n"
    echo -e "${YELLOW}[2]${NC} ${BOLD}OAuth (Browser)${NC}"
    echo -e "    ${CYAN}→${NC} Opens browser for login\n"
    echo -e "${YELLOW}[3]${NC} ${BOLD}Skip${NC}\n"

    while true; do
        read -p "$(echo -e "${BOLD}Choice [1-3]:${NC} ")" choice
        case $choice in
            1)
                read -sp "$(echo -e "${BOLD}Auth key (hidden):${NC} ")" authkey
                echo ""
                if [[ -n "$authkey" ]]; then
                    tailscale up --authkey="$authkey" &>>"$LOG_FILE"
                    local ts_ip
                    ts_ip=$(tailscale ip -4 2>/dev/null || echo "")
                    print_success "Authenticated"
                    [[ -n "$ts_ip" ]] && print_success "Tailscale IP: $ts_ip"
                else
                    print_error "No key provided"
                fi
                break
                ;;
            2)
                tailscale up
                print_success "Authenticated via OAuth"
                break
                ;;
            3)
                print_warning "Skipped. Run 'sudo tailscale up' later."
                break
                ;;
            *) echo -e "${RED}Enter 1, 2, or 3${NC}" ;;
        esac
    done
    echo ""
}

# ============================================================
# VM OPTIMIZATION (for setup command)
# ============================================================
optimize_vm() {
    echo -e "${YELLOW}⚙️  VM Optimization${NC}\n"

    detect_os

    if ask_permission "Remove bloat packages?" "Removes unattended-upgrades, chrony (~100MB saved)"; then
        echo -ne "   ${CYAN}→${NC} Removing bloat..."
        systemctl stop unattended-upgrades 2>/dev/null || true
        systemctl disable unattended-upgrades 2>/dev/null || true
        apt purge -y unattended-upgrades chrony &>>"$LOG_FILE" || true
        apt autoremove -y &>>"$LOG_FILE" || true
        echo -e " ${GREEN}✓${NC}"
    fi

    if ask_permission "Install Podman?" "Lightweight container runtime (~30MB)"; then
        ensure_podman
    fi

    if ask_permission "Create 2GB swap?" "Prevents OOM kills on low-RAM VMs"; then
        ensure_swap
    fi

    if ask_permission "Optimize kernel?" "Sets swappiness=10, cache_pressure=50"; then
        if ! grep -q "vm.swappiness=10" /etc/sysctl.conf 2>/dev/null; then
            echo 'vm.swappiness=10' | tee -a /etc/sysctl.conf > /dev/null
        fi
        if ! grep -q "vm.vfs_cache_pressure=50" /etc/sysctl.conf 2>/dev/null; then
            echo 'vm.vfs_cache_pressure=50' | tee -a /etc/sysctl.conf > /dev/null
        fi
        sysctl -p &>>"$LOG_FILE" || true
        print_success "Kernel optimized"
    fi

    echo ""
}

# ============================================================
# DEPLOY INTERACTIVE (main orchestrator — 6 phases)
# ============================================================
deploy_interactive() {
    show_banner

    # Check Podman
    if ! command -v podman &>/dev/null; then
        print_error "Podman not installed. Run 'sudo xecurenet setup' first."
        exit 1
    fi

    echo -e "${GREEN}${BOLD}🚀 XecureNet Deploy Wizard${NC}\n"
    echo -e "${DIM}   6-phase deployment: Scan → Select → Inputs → Budget → Deploy → Summary${NC}\n"

    # Phase 0: VM Scan
    vm_scan

    # Phase 1+2: Select services + Collect inputs
    echo -e "${BLUE}${BOLD}📦 Phase 1: Service Selection${NC}\n"
    select_services || return
    collect_inputs

    # Phase 3: RAM Budget Check
    ram_budget_check || return

    # Pre-deploy: ensure base dependencies
    echo -e "${BLUE}${BOLD}🔧 Pre-Deploy Setup${NC}\n"
    ensure_swap
    ensure_podman

    # Check if any service needs Tailscale/Cloudflare
    local needs_tailscale=false
    local needs_cloudflare=false
    for i in "${!SELECTED_IDS[@]}"; do
        [[ "${SEL_ACCESS[$i]}" == "funnel" ]] && needs_tailscale=true
        [[ "${SEL_ACCESS[$i]}" == "cloudflare" ]] && needs_cloudflare=true
    done
    $needs_tailscale && ensure_tailscale
    $needs_cloudflare && ensure_cloudflared

    # Phase 4: Deploy
    echo -e "\n${BLUE}${BOLD}🚀 Phase 4: Deploying Services${NC}"

    for i in "${!SELECTED_IDS[@]}"; do
        deploy_single_service "$i" || true
    done

    # Setup access for each service
    echo -e "\n${BLUE}${BOLD}🌐 Setting Up Access${NC}"
    for i in "${!SELECTED_IDS[@]}"; do
        setup_access "$i"
    done

    # Create systemd services
    echo -e "\n${CYAN}⚙️  Creating auto-start services${NC}"
    for i in "${!SELECTED_IDS[@]}"; do
        local sid="${SELECTED_IDS[$i]}"
        local cname="${SEL_CONTAINER[$i]}"
        if [[ "$sid" == "pg-redis" ]]; then
            create_systemd_service "${cname}-pg"
            create_systemd_service "${cname}-redis"
        else
            create_systemd_service "$cname"
        fi
    done
    print_success "Systemd services created (auto-start on reboot)"

    # Cleanup
    run_cleanup

    # Phase 5: Summary
    print_summary_card
    print_agent_training_card
}

