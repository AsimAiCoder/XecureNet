# ============================================================
# SHOW STATUS
# ============================================================
show_status() {
    show_banner

    local ram_total ram_used ram_available swap_total swap_used
    ram_total=$(free -m | awk '/^Mem:/{print $2}')
    ram_used=$(free -m | awk '/^Mem:/{print $3}')
    ram_available=$(free -m | awk '/^Mem:/{print $7}')
    swap_total=$(free -h | awk '/^Swap:/{print $2}')
    swap_used=$(free -h | awk '/^Swap:/{print $3}')

    local tailscale_ip="Not installed"
    local tailscale_status="not installed"
    if command -v tailscale &>/dev/null; then
        tailscale_ip=$(tailscale ip -4 2>/dev/null || echo "Not configured")
        tailscale_status=$(systemctl is-active tailscaled 2>/dev/null || echo "inactive")
    fi

    local podman_status="Not installed"
    local containers=0
    if command -v podman &>/dev/null; then
        podman_status="Active"
        containers=$(podman ps -q 2>/dev/null | wc -l)
    fi

    echo -e "${BLUE}📊 System Status${NC}\n"

    echo -e "   ${CYAN}Memory:${NC}"
    echo "   ├─ Total:     ${ram_total} MB"
    echo "   ├─ Used:      ${ram_used} MB"
    echo -e "   └─ Available: ${GREEN}${ram_available} MB${NC}"
    echo ""

    echo -e "   ${CYAN}Swap:${NC}"
    echo "   ├─ Total: ${swap_total}"
    echo "   └─ Used:  ${swap_used}"
    echo ""

    echo -e "   ${CYAN}Network:${NC}"
    if [[ "$tailscale_ip" != "Not configured" ]] && [[ "$tailscale_ip" != "Not installed" ]]; then
        echo -e "   └─ Tailscale IP: ${GREEN}${tailscale_ip}${NC}"
    else
        echo -e "   └─ Tailscale: ${YELLOW}${tailscale_ip}${NC}"
    fi
    echo ""

    echo -e "   ${CYAN}Services:${NC}"
    echo -e "   ├─ Podman:        ${GREEN}✓${NC} $podman_status"
    if [[ "$tailscale_status" == "active" ]]; then
        echo -e "   ├─ Tailscale:     ${GREEN}✓${NC} Connected"
    else
        echo -e "   ├─ Tailscale:     ${YELLOW}⚠${NC} $tailscale_status"
    fi
    echo -e "   └─ Containers:    ${GREEN}${containers} running${NC}"
    echo ""

    if [[ $containers -gt 0 ]] && command -v podman &>/dev/null; then
        echo -e "   ${CYAN}Deployed Containers:${NC}\n"
        podman ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null | while IFS= read -r line; do
            echo "   $line"
        done
        echo ""

        echo -e "   ${CYAN}Container Memory Usage:${NC}\n"
        podman stats --no-stream --format "table {{.Name}}\t{{.MemUsage}}\t{{.MemPerc}}" 2>/dev/null | while IFS= read -r line; do
            echo "   $line"
        done
        echo ""
    fi
}

# ============================================================
# REMOVE SERVICE
# ============================================================
remove_service() {
    echo -e "${RED}🗑️  Remove Service${NC}\n"

    local running
    running=$(podman ps -a --format "{{.Names}}" 2>/dev/null)
    if [[ -z "$running" ]]; then
        print_info "No services deployed."
        return
    fi

    echo -e "${BOLD}Containers:${NC}\n"
    local idx=1
    local containers=()
    while IFS= read -r name; do
        local status
        status=$(podman inspect "$name" --format "{{.State.Status}}" 2>/dev/null)
        echo -e "   ${YELLOW}[$idx]${NC} $name ${DIM}($status)${NC}"
        containers+=("$name")
        ((idx++))
    done <<< "$running"

    echo -e "   ${YELLOW}[0]${NC} Cancel\n"

    read -p "$(echo -e "${BOLD}Remove which service? [0-$((idx-1))]:${NC} ")" choice
    if [[ "$choice" == "0" ]] || [[ -z "$choice" ]]; then
        return
    fi

    if [[ $choice -ge 1 ]] && [[ $choice -lt $idx ]]; then
        local target="${containers[$((choice-1))]}"

        echo -e "\n${YELLOW}This will:${NC}"
        echo -e "   • Stop and remove container: $target"
        echo -e "   • Remove systemd service (if any)"
        echo -e "   ${DIM}Note: Data volumes in $PROJECTS_DIR are NOT deleted${NC}\n"

        read -p "$(echo -e "${BOLD}Confirm removal? [y/N]:${NC} ")" confirm
        case "$confirm" in
            [Yy]*)
                echo -ne "   ${CYAN}→${NC} Removing $target..."
                podman stop "$target" &>/dev/null || true
                podman rm -f "$target" &>/dev/null || true
                # Remove systemd service
                rm -f "/etc/systemd/system/podman-${target}.service" 2>/dev/null
                systemctl daemon-reload &>/dev/null || true
                # Clean from registry
                sed -i "/^[^|]*|${target}|/d" "$DEPLOY_REGISTRY" 2>/dev/null || true
                echo -e " ${GREEN}✓${NC}"
                print_success "$target removed"
                print_info "Data preserved in $PROJECTS_DIR/"
                ;;
            *)
                echo -e "${CYAN}Cancelled.${NC}"
                ;;
        esac
    else
        print_error "Invalid choice"
    fi
}

