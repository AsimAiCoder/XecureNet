# ============================================================
# PHASE 0: VM SCAN
# ============================================================
vm_scan() {
    echo -e "${BLUE}${BOLD}🔍 Phase 0: VM Scan${NC}\n"

    detect_os

    local ram_total ram_used ram_available swap_total disk_total disk_avail
    ram_total=$(free -m | awk '/^Mem:/{print $2}')
    ram_used=$(free -m | awk '/^Mem:/{print $3}')
    ram_available=$(free -m | awk '/^Mem:/{print $7}')
    swap_total=$(free -m | awk '/^Swap:/{print $2}')
    disk_total=$(df -h / | awk 'NR==2{print $2}')
    disk_avail=$(df -h / | awk 'NR==2{print $4}')

    local cpu_cores cpu_model
    cpu_cores=$(nproc 2>/dev/null || echo "?")
    cpu_model=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | xargs || echo "Unknown")

    local inet="No"
    if ping -c 1 -W 3 8.8.8.8 &>/dev/null; then
        inet="Yes"
    fi

    local ts_status="Not installed"
    local ts_ip=""
    if command -v tailscale &>/dev/null; then
        ts_ip=$(tailscale ip -4 2>/dev/null || echo "")
        if [[ -n "$ts_ip" ]]; then
            ts_status="Connected ($ts_ip)"
        else
            ts_status="Installed (not connected)"
        fi
    fi

    local podman_status="Not installed"
    local containers_running=0
    if command -v podman &>/dev/null; then
        podman_status="Installed ($(podman --version 2>/dev/null | awk '{print $3}'))"
        containers_running=$(podman ps -q 2>/dev/null | wc -l)
    fi

    echo -e "   ${CYAN}╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "   ${CYAN}║${NC}              ${BOLD}📊 VM Specifications${NC}                   ${CYAN}║${NC}"
    echo -e "   ${CYAN}╠══════════════════════════════════════════════════════╣${NC}"
    printf "   ${CYAN}║${NC}  OS:          %-38s ${CYAN}║${NC}\n" "$OS_PRETTY"
    printf "   ${CYAN}║${NC}  CPU:         %-38s ${CYAN}║${NC}\n" "${cpu_cores} cores — ${cpu_model:0:30}"
    printf "   ${CYAN}║${NC}  RAM:         %-38s ${CYAN}║${NC}\n" "${ram_total} MB total, ${ram_available} MB available"
    printf "   ${CYAN}║${NC}  Swap:        %-38s ${CYAN}║${NC}\n" "${swap_total} MB"
    printf "   ${CYAN}║${NC}  Disk:        %-38s ${CYAN}║${NC}\n" "${disk_total} total, ${disk_avail} available"
    printf "   ${CYAN}║${NC}  Internet:    %-38s ${CYAN}║${NC}\n" "$inet"
    printf "   ${CYAN}║${NC}  Tailscale:   %-38s ${CYAN}║${NC}\n" "$ts_status"
    printf "   ${CYAN}║${NC}  Podman:      %-38s ${CYAN}║${NC}\n" "$podman_status"
    printf "   ${CYAN}║${NC}  Containers:  %-38s ${CYAN}║${NC}\n" "${containers_running} running"
    echo -e "   ${CYAN}╚══════════════════════════════════════════════════════╝${NC}"
    echo ""

    if [[ "$inet" == "No" ]]; then
        print_error "No internet connectivity. Cannot proceed."
        exit 1
    fi

    if [[ $ram_total -lt 400 ]]; then
        print_warning "Very low RAM ($ram_total MB). Performance may be poor."
    fi

    # Store for later use
    VM_RAM_AVAILABLE=$ram_available
    VM_SWAP_TOTAL=$swap_total
}

# ============================================================
# PHASE 1: SERVICE MENU
# ============================================================
show_services_menu() {
    local avail_ram
    avail_ram=$(get_available_ram)
    local used_ram
    used_ram=$(get_container_ram_used)
    local free_ram=$((avail_ram - used_ram))

    echo -e "${CYAN}${BOLD}📦 Service Catalog (25 services)${NC}\n"
    echo -e "${DIM}   Available RAM: ${NC}${GREEN}${free_ram} MB${NC}${DIM} (${avail_ram} total - ${used_ram} used)${NC}\n"

    local last_cat=""
    for svc in "${SERVICES[@]}"; do
        local snum=$(get_svc_field "$svc" 1)
        local sname=$(get_svc_field "$svc" 3)
        local sram=$(get_svc_field "$svc" 4)
        local scat=$(get_svc_field "$svc" 5)
        local sport=$(get_svc_field "$svc" 7)

        # Print category header on change
        if [[ "$scat" != "$last_cat" ]]; then
            local cat_label=""
            for i in "${!CATEGORY_NAMES[@]}"; do
                if [[ "${CATEGORY_NAMES[$i]}" == "$scat" ]]; then
                    cat_label="${CATEGORY_LABELS[$i]}"
                    break
                fi
            done
            echo -e "\n   ${BOLD}${cat_label}${NC}"
            last_cat="$scat"
        fi

        # Color-code RAM fit
        local color="${GREEN}"
        [[ $sram -gt $free_ram ]] && color="${RED}"
        [[ $sram -gt $((free_ram / 2)) ]] && [[ $sram -le $free_ram ]] && color="${YELLOW}"

        local port_info=""
        if [[ "$sport" != "0" ]]; then
            port_info=":${sport}"
        fi

        printf "   ${YELLOW}[%2d]${NC} %-40s ${color}~%3dMB${NC} ${DIM}%s${NC}\n" \
            "$snum" "$sname" "$sram" "$port_info"
    done

    echo ""
    echo -e "   ${YELLOW}[ 0]${NC} ${BOLD}🔙 Done / Cancel${NC}\n"
    echo -e "${DIM}   Color: ${GREEN}●${NC}${DIM} Fits  ${YELLOW}●${NC}${DIM} Tight  ${RED}●${NC}${DIM} Needs swap${NC}\n"

    echo -e "${DIM}   Example packs:${NC}"
    echo -e "   ${DIM}• Blog + Monitor:       1, 21        (~95 MB)${NC}"
    echo -e "   ${DIM}• Full-stack Bot:       5, 16, 21    (~150 MB)${NC}"
    echo -e "   ${DIM}• SaaS Starter:         14, 18, 21   (~205 MB)${NC}\n"
}

