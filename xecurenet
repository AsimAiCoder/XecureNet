# ACCESS SETUP (Tailscale Funnel / Cloudflare Tunnel / Private)
# ============================================================
setup_access() {
    local idx="$1"
    local sid="${SELECTED_IDS[$idx]}"
    local cname="${SEL_CONTAINER[$idx]}"
    local access="${SEL_ACCESS[$idx]}"
    local domain="${SEL_DOMAIN[$idx]}"

    local svc_entry=""
    for svc in "${SERVICES[@]}"; do
        [[ "$(get_svc_field "$svc" 2)" == "$sid" ]] && svc_entry="$svc"
    done
    local sport=$(get_svc_field "$svc_entry" 7)
    local sname=$(get_svc_field "$svc_entry" 3)

    # Skip no-port services
    [[ "$sport" == "0" ]] && return 0

    case "$access" in
        funnel)
            echo -ne "   ${CYAN}→${NC} Enabling Tailscale Funnel for $sname..."
            if command -v tailscale &>/dev/null; then
                tailscale funnel --bg "$sport" &>>"$LOG_FILE" && {
                    echo -e " ${GREEN}✓${NC}"
                    local hostname
                    hostname=$(tailscale status --json 2>/dev/null | grep -o '"DNSName":"[^"]*"' | head -1 | cut -d'"' -f4 | sed 's/\.$//')
                    print_success "Public: https://${hostname}:${sport}"
                } || {
                    echo -e " ${RED}✗${NC}"
                    print_error "Funnel failed. Enable at: Tailscale admin → DNS → Funnel"
                }
            else
                echo -e " ${RED}✗${NC}"
                print_error "Tailscale not installed"
            fi
            ;;

        cloudflare)
            echo -ne "   ${CYAN}→${NC} Setting up Cloudflare Tunnel for $sname..."
            ensure_cloudflared
            if command -v cloudflared &>/dev/null && [[ -n "$domain" ]]; then
                cloudflared tunnel --url "http://localhost:$sport" --hostname "$domain" &>>"$LOG_FILE" &
                echo -e " ${GREEN}✓${NC}"
                print_success "Cloudflare Tunnel: $domain -> localhost:$sport"
            else
                echo -e " ${YELLOW}⚠${NC}"
                print_warning "Run manually: cloudflared tunnel --url http://localhost:$sport"
            fi
            ;;

        private|*)
            local ts_ip
            ts_ip=$(tailscale ip -4 2>/dev/null || echo "")
            if [[ -n "$ts_ip" ]]; then
                print_info "$sname: http://${ts_ip}:${sport} (Tailscale)"
            else
                print_info "$sname: http://localhost:${sport} (local only)"
            fi
            ;;
    esac
}

# ============================================================
# SYSTEMD SERVICE GENERATION (auto-start on reboot)
# ============================================================
create_systemd_service() {
    local cname="$1"

    # Only works on systemd systems with SUDO_USER
    if [[ -z "${SUDO_USER:-}" ]]; then
        return 0
    fi

    local uid
    uid=$(id -u "$SUDO_USER" 2>/dev/null || return 0)
    local systemd_dir="/etc/systemd/system"
    local service_file="${systemd_dir}/podman-${cname}.service"

    cat > "$service_file" << SVCEOF
[Unit]
Description=Podman container: ${cname}
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
Restart=on-failure
RestartSec=10
ExecStart=/usr/bin/podman start ${cname}
ExecStop=/usr/bin/podman stop -t 10 ${cname}
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
SVCEOF

    systemctl daemon-reload &>>"$LOG_FILE" || true
    systemctl enable "podman-${cname}" &>>"$LOG_FILE" || true
    log "Created systemd service: podman-${cname}"
}

# ============================================================
# CLEANUP (prune images, fix permissions)
# ============================================================
run_cleanup() {
    echo -e "\n${CYAN}🧹 Cleanup${NC}"

    # Prune dangling images
    echo -ne "   ${CYAN}→${NC} Pruning unused images..."
    podman image prune -f &>>"$LOG_FILE" || true
    echo -e " ${GREEN}✓${NC}"

    # Fix permissions on projects dir
    if [[ $EUID -eq 0 ]] && [[ -n "${SUDO_USER:-}" ]]; then
        echo -ne "   ${CYAN}→${NC} Fixing file ownership..."
        chown -R "$SUDO_USER:$(id -gn "$SUDO_USER")" "$PROJECTS_DIR" 2>/dev/null || true
        chown -R "$SUDO_USER:$(id -gn "$SUDO_USER")" "$CONFIG_DIR" 2>/dev/null || true
        echo -e " ${GREEN}✓${NC}"
    fi

    # Optimize kernel if not done
    if ! grep -q "vm.swappiness=10" /etc/sysctl.conf 2>/dev/null; then
        echo -ne "   ${CYAN}→${NC} Optimizing kernel..."
        echo 'vm.swappiness=10' | tee -a /etc/sysctl.conf > /dev/null
        echo 'vm.vfs_cache_pressure=50' | tee -a /etc/sysctl.conf > /dev/null
        sysctl -p &>>"$LOG_FILE" || true
        echo -e " ${GREEN}✓${NC}"
    fi
}

