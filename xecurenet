# PHASE 2: SERVICE SELECTION & INPUT COLLECTION
# ============================================================

# Parallel arrays for collected inputs
SELECTED_IDS=()
SEL_CONTAINER=()
SEL_ACCESS=()
SEL_DOMAIN=()
SEL_TOKEN=()
SEL_DB_NAME=()
SEL_DB_PASS=()
CUR_IDX=0

select_services() {
    show_services_menu

    while true; do
        read -p "$(echo -e "${BOLD}Enter service number (0 when done):${NC} ")" num

        if [[ "$num" == "0" ]]; then
            break
        fi

        if ! [[ "$num" =~ ^[0-9]+$ ]] || [[ $num -lt 1 ]] || [[ $num -gt ${#SERVICES[@]} ]]; then
            echo -e "${RED}Invalid. Enter 1-${#SERVICES[@]} or 0.${NC}"
            continue
        fi

        local svc="${SERVICES[$((num-1))]}"
        local sid=$(get_svc_field "$svc" 2)
        local sname=$(get_svc_field "$svc" 3)
        local sram=$(get_svc_field "$svc" 4)

        # Check duplicates
        local dup=false
        for s in "${SELECTED_IDS[@]}"; do
            [[ "$s" == "$sid" ]] && dup=true
        done
        if $dup; then
            echo -e "${YELLOW}Already selected: $sname${NC}"
            continue
        fi

        # Check if already deployed
        if command -v podman &>/dev/null && podman ps -a --format "{{.Names}}" 2>/dev/null | grep -q "^${sid}$"; then
            print_warning "$sname already deployed. Remove first: podman rm -f $sid"
            continue
        fi

        SELECTED_IDS+=("$sid")
        echo -e "${GREEN}✓${NC} Added: $sname (~${sram}MB)"
    done

    if [[ ${#SELECTED_IDS[@]} -eq 0 ]]; then
        echo -e "\n${YELLOW}No services selected. Exiting.${NC}"
        return 1
    fi
    return 0
}

collect_inputs() {
    echo -e "\n${BLUE}${BOLD}📝 Phase 2: Input Collection${NC}"
    echo -e "${DIM}   Collecting all inputs upfront before deployment.${NC}\n"

    for i in "${!SELECTED_IDS[@]}"; do
        CUR_IDX=$i
        local sid="${SELECTED_IDS[$i]}"
        local svc_entry=""
        for svc in "${SERVICES[@]}"; do
            [[ "$(get_svc_field "$svc" 2)" == "$sid" ]] && svc_entry="$svc"
        done

        local sname=$(get_svc_field "$svc_entry" 3)
        local sport=$(get_svc_field "$svc_entry" 7)
        local stype=$(get_svc_field "$svc_entry" 6)

        echo -e "${CYAN}── $sname ──${NC}"

        # Container name
        local default_name="$sid"
        read -p "$(echo -e "   Container name [${default_name}]: ")" cname
        SEL_CONTAINER+=("${cname:-$default_name}")

        # Bot tokens
        SEL_TOKEN+=("")
        SEL_DB_NAME+=("")
        SEL_DB_PASS+=("")

        case "$sid" in
            telegram-bot-py|telegram-bot-node)
                read -p "$(echo -e "   Telegram Bot Token: ")" token
                SEL_TOKEN[$i]="${token:-YOUR_BOT_TOKEN_HERE}"
                ;;
            discord-bot-py|discord-bot-node)
                read -p "$(echo -e "   Discord Bot Token: ")" token
                SEL_TOKEN[$i]="${token:-YOUR_BOT_TOKEN_HERE}"
                ;;
            whatsapp-bot)
                print_info "   WhatsApp: Scan QR after deployment (podman logs -f ${SEL_CONTAINER[$i]})"
                ;;
            combo-bot)
                read -p "$(echo -e "   Telegram Bot Token: ")" tg_token
                read -p "$(echo -e "   Discord Bot Token: ")" dc_token
                SEL_TOKEN[$i]="${tg_token:-YOUR_TG_TOKEN}|${dc_token:-YOUR_DC_TOKEN}"
                ;;
            postgres|pg-redis)
                read -p "$(echo -e "   Database name [mydb]: ")" dbname
                SEL_DB_NAME[$i]="${dbname:-mydb}"
                local gen_pass
                gen_pass=$(generate_password 16)
                read -p "$(echo -e "   Database password [auto: ${gen_pass:0:4}...]: ")" dbpass
                SEL_DB_PASS[$i]="${dbpass:-$gen_pass}"
                ;;
        esac

        # Access method (only for services with ports)
        SEL_ACCESS+=("private")
        SEL_DOMAIN+=("")
        if [[ "$sport" != "0" ]]; then
            echo -e "   ${BOLD}Access method:${NC}"
            echo -e "   ${YELLOW}[1]${NC} Private (Tailscale only) ${GREEN}(Default)${NC}"
            echo -e "   ${YELLOW}[2]${NC} Tailscale Funnel (free HTTPS)"
            echo -e "   ${YELLOW}[3]${NC} Cloudflare Tunnel (custom domain)"
            read -p "$(echo -e "   Choice [1]: ")" access
            case "$access" in
                2) SEL_ACCESS[$i]="funnel" ;;
                3)
                    SEL_ACCESS[$i]="cloudflare"
                    read -p "$(echo -e "   Domain (e.g. app.example.com): ")" domain
                    SEL_DOMAIN[$i]="${domain}"
                    ;;
                *) SEL_ACCESS[$i]="private" ;;
            esac
        fi
        echo ""
    done
}

# ============================================================
# PHASE 3: RAM BUDGET CHECK
# ============================================================
ram_budget_check() {
    echo -e "${BLUE}${BOLD}📊 Phase 3: RAM Budget Check${NC}\n"

    local total_ram_needed=0
    for sid in "${SELECTED_IDS[@]}"; do
        for svc in "${SERVICES[@]}"; do
            if [[ "$(get_svc_field "$svc" 2)" == "$sid" ]]; then
                local sram=$(get_svc_field "$svc" 4)
                total_ram_needed=$((total_ram_needed + sram))
            fi
        done
    done

    local avail_ram
    avail_ram=$(get_available_ram)
    local used_ram
    used_ram=$(get_container_ram_used)
    local free_ram=$((avail_ram - used_ram))
    local remaining=$((free_ram - total_ram_needed))
    local swap_total
    swap_total=$(free -m | awk '/^Swap:/{print $2}')

    echo -e "   ┌──────────────────────────────────────────┐"
    printf "   │ Free RAM:            %-20s │\n" "${free_ram} MB"
    printf "   │ Selected total:      %-20s │\n" "${total_ram_needed} MB"
    printf "   │ Remaining after:     %-20s │\n" "${remaining} MB"
    printf "   │ Swap available:      %-20s │\n" "${swap_total} MB"
    echo -e "   └──────────────────────────────────────────┘"

    if [[ $remaining -gt 150 ]]; then
        echo -e "   ${GREEN}✓ SAFE — Plenty of headroom.${NC}\n"
        return 0
    elif [[ $remaining -gt 0 ]]; then
        echo -e "   ${YELLOW}⚠ TIGHT — Will work, but little headroom. Swap helps.${NC}\n"
        return 0
    else
        echo -e "   ${RED}⚠ OVER by $((remaining * -1)) MB — Will rely heavily on swap.${NC}\n"
        read -p "$(echo -e "${BOLD}Deploy anyway? [y/N]:${NC} ")" confirm
        case "$confirm" in
            [Yy]*) echo -e "${GREEN}✓${NC} Proceeding...\n"; return 0;;
            *)     echo -e "${RED}Cancelled.${NC}"; return 1;;
        esac
    fi
}

# ============================================================
# BASE SETUP: Swap, Podman, Tailscale, Cloudflared
# ============================================================
ensure_swap() {
    if [ -f /swapfile ]; then
        return 0
    fi
    echo -ne "   ${CYAN}→${NC} Creating 2GB swap..."
    if command -v fallocate &>/dev/null; then
        fallocate -l 2G /swapfile 2>>"$LOG_FILE" || dd if=/dev/zero of=/swapfile bs=1M count=2048 status=none 2>>"$LOG_FILE"
    else
        dd if=/dev/zero of=/swapfile bs=1M count=2048 status=none 2>>"$LOG_FILE"
    fi
    chmod 600 /swapfile
    mkswap /swapfile &>>"$LOG_FILE"
    swapon /swapfile 2>>"$LOG_FILE" || true
    if ! grep -q '/swapfile' /etc/fstab; then
        echo '/swapfile none swap sw 0 0' | tee -a /etc/fstab > /dev/null
    fi
    echo -e " ${GREEN}✓${NC}"
}

ensure_podman() {
    if command -v podman &>/dev/null; then
        return 0
    fi
    echo -ne "   ${CYAN}→${NC} Installing Podman..."
    detect_os
    apt-get update -qq &>>"$LOG_FILE"
    case "$OS_ID" in
        ubuntu|debian)
            apt-get install -y -qq podman &>>"$LOG_FILE"
            ;;
        *)
            apt-get install -y -qq podman &>>"$LOG_FILE" || {
                print_error "Podman install failed. Install manually."
                return 1
            }
            ;;
    esac
    if [[ -n "${SUDO_USER:-}" ]]; then
        loginctl enable-linger "$SUDO_USER" 2>/dev/null || true
    fi
    echo -e " ${GREEN}✓${NC}"
}

ensure_tailscale() {
