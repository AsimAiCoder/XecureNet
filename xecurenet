# ============================================================
# OS DETECTION (reads vars via grep, not source)
# ============================================================
OS_ID=""
OS_VERSION=""
OS_PRETTY=""

detect_os() {
    if [ -f /etc/os-release ]; then
        OS_ID=$(grep -oP '^ID=\K.*' /etc/os-release | tr -d '"')
        OS_VERSION=$(grep -oP '^VERSION_ID=\K.*' /etc/os-release | tr -d '"')
        OS_PRETTY=$(grep -oP '^PRETTY_NAME=\K.*' /etc/os-release | tr -d '"')
    else
        print_error "Cannot detect OS. /etc/os-release not found."
        exit 1
    fi

    case "$OS_ID" in
        debian|ubuntu) ;;
        *)
            print_warning "Unsupported OS: $OS_PRETTY"
            print_warning "XecureNet is tested on Debian 12+ and Ubuntu 22.04+"
            print_info "Continuing anyway — some features may not work"
            ;;
    esac
}

# ============================================================
# ROOT CHECK
# ============================================================
check_root() {
    if [[ $EUID -ne 0 ]]; then
        print_error "This script must be run as root (use sudo)"
        exit 1
    fi
    if [[ -z "${SUDO_USER:-}" ]]; then
        print_warning "Running as direct root (no sudo detected)"
        print_info "Some user-level features may not work. Recommended: use sudo"
    fi
}

# ============================================================
# UTILITY FUNCTIONS
# ============================================================
generate_password() {
    local len="${1:-16}"
    tr -dc 'A-Za-z0-9!@#$%' < /dev/urandom | head -c "$len" 2>/dev/null || openssl rand -base64 "$len" | head -c "$len"
}

ask_permission() {
    local question="$1"
    local details="$2"
    if [[ "$SETUP_MODE" == "agent" ]]; then
        echo -e "${GREEN}✓${NC} Auto-approved: $question"
        return 0
    fi
    echo -e "\n${YELLOW}❓ $question${NC}"
    if [[ -n "$details" ]]; then
        echo -e "${CYAN}ℹ️  Details: $details${NC}"
    fi
    while true; do
        read -p "$(echo -e "${BOLD}Continue? [Y/n]:${NC} ")" choice
        case "$choice" in
            [Yy]*|"") return 0;;
            [Nn]*)    echo -e "${RED}⏭️  Skipped${NC}"; return 1;;
            *)        echo -e "${RED}Please answer Y or N${NC}";;
        esac
    done
}

select_mode() {
    if [[ "$SETUP_MODE" == "agent" ]]; then
        echo -e "${GREEN}✓${NC} Agent Mode (set via environment)\n"
        return
    fi
    echo -e "${CYAN}${BOLD}🎯 Select Setup Mode:${NC}\n"
    echo -e "${YELLOW}[1]${NC} ${BOLD}Manual Mode${NC} - Step-by-step ${GREEN}(Recommended)${NC}"
    echo -e "    ${CYAN}→${NC} You'll be asked before each action\n"
    echo -e "${YELLOW}[2]${NC} ${BOLD}Agent Mode${NC} - Fully automated ${BLUE}(For experts)${NC}"
    echo -e "    ${CYAN}→${NC} No prompts, runs automatically\n"
    while true; do
        read -p "$(echo -e "${BOLD}Your choice [1-2]:${NC} ")" mode
        case "$mode" in
            1) SETUP_MODE="manual"; echo -e "${GREEN}✓${NC} Manual Mode selected\n"; break;;
            2) SETUP_MODE="agent";  echo -e "${GREEN}✓${NC} Agent Mode selected\n"; break;;
            *) echo -e "${RED}Please enter 1 or 2${NC}";;
        esac
    done
}

# ============================================================
# RAM CALCULATOR (FIXED: proper unit handling)
# ============================================================
get_available_ram() {
    local total_avail
    total_avail=$(free -m | awk '/^Mem:/{print $7}')
    local reserved=150
    local container_ram=$((total_avail - reserved))
    [[ $container_ram -lt 0 ]] && container_ram=0
    echo "$container_ram"
}

get_container_ram_used() {
    if command -v podman &>/dev/null; then
        podman stats --no-stream --format "{{.MemUsage}}" 2>/dev/null | awk -F'/' '{
            val = $1; gsub(/[^0-9.kKmMgG]/, "", val)
            num = val + 0; unit = val; gsub(/[0-9.]/, "", unit)
            if (tolower(unit) ~ /g/) num *= 1024
            else if (tolower(unit) ~ /k/) num /= 1024
            sum += num
        } END { printf "%d", sum }' 2>/dev/null || echo "0"
    else
        echo "0"
    fi
}

